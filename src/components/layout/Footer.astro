---
import { site } from '../../data/site';
import { socialLinks } from '../../data/social';
---

<footer id="footer">
	<ul class="icons">
		{socialLinks.map((link) => (
			<li>
				<a href={link.href} aria-label={link.label}>{link.label}</a>
			</li>
		))}
	</ul>
	<ul class="copyright">
		<li>{site.footerText}</li>
	</ul>
</footer>
