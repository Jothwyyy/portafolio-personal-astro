---
import PageLayout from '../layouts/PageLayout.astro';
import Banner from '../components/sections/Banner.astro';
import Intro from '../components/sections/Intro.astro';
import One from '../components/sections/One.astro';
import Features from '../components/sections/Features.astro';
import PortfolioGrid from '../components/sections/PortfolioGrid.astro';
import Cta from '../components/sections/Cta.astro';
import { buildPageTitle } from '../lib/seo';

const headerType = "alt"
---

<PageLayout title={buildPageTitle('Inicio')} bodyClass="index" headerType={headerType}>
	<Banner />
	<article id="main">
		<Intro />
		<One />
		<Features />
		<PortfolioGrid />
	</article>
	<Cta />
</PageLayout>
