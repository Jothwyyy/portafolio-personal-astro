---
import PageLayout from '../layouts/PageLayout.astro';
import SidebarHeader from '../components/sections/SidebarHeader.astro';
import SidebarContent from '../components/sections/SidebarContent.astro';
import RelatedCards from '../components/sections/RelatedCards.astro';
import { buildPageTitle } from '../lib/seo'
import { noSidebarPage } from '../data/noSidebar';
---

<PageLayout title={buildPageTitle('No Sidebar')} bodyClass='no-sidebar is-preload'>
	<article id="main">	
		<SidebarHeader header={noSidebarPage.header}/>
		<section class="wrapper style4 container">
			<SidebarContent content={noSidebarPage.content}/>
		</section>
		<RelatedCards items={noSidebarPage.related}/>
	</article>
</PageLayout>
